local player = ...
local byp = function()
	local succes, error = pcall(function()
		local Event = game:GetService("ReplicatedStorage").Remotes.EquipSword
		local OldFireServer; OldFireServer = hookfunction(Event.FireServer, function(...)
			local self = ...

			if rawequal(self, Event) then
				local Args = table.pack(...)

				if Args[2] == "UseSword " then 
					return OldFireServer(self, {"UseSword", Args[3]})
				end
			end
			return OldFireServer(self, ...)
		end) 

		local tool = player.Backpack:FindFirstChildOfClass("Tool") or player.Character:FindFirstChildOfClass("Tool")
		Event = tool:FindFirstChild("Grips"):FindFirstChildOfClass("RemoteEvent")

		local OldFireServer; OldFireServer = hookfunction(Event.FireServer, function(...)
			local self = ...

			if rawequal(self, Event) then return end
			return OldFireServer(self, ...)
		end)
	end)
	if not succes then warn(error) end
end

local IDS = {13594360346, 11515893037, 6356763358, 6361937392}
if table.find(IDS, game.PlaceId) then byp() print("i") end
